# Login Helper v2 — local environment config example
# Copy this file to `.env.local` and fill every field. `.env.local` is gitignored.
#
# Each milestone of the plan assumes these values are present and correct.
# If any field is empty, the build will surface the missing variable.

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Web SDK config (from Firebase console → Project settings →
# Your apps → Web app → "Firebase SDK snippet" → Config)
# ─────────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Stable Chrome extension identity
# EXTENSION_KEY  = base64 RSA public key, injected into manifest "key" field.
#                  Required — build fails without it.
# EXTENSION_ID   = the 32-char ID Chrome derives from EXTENSION_KEY; used to
#                  register the OAuth client and to verify the loaded
#                  extension. Optional — if set, the build prints a warning
#                  when it disagrees with the value derived from EXTENSION_KEY.
# ─────────────────────────────────────────────────────────────────────────────
EXTENSION_KEY=
EXTENSION_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Google Cloud OAuth client ID (from APIs & Services → Credentials →
# OAuth client ID, Application type: Chrome Extension, Application ID:
# value of EXTENSION_ID above)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Firebase project ID — only used by the `firebase deploy` shell command
# (e.g. `firebase use $FIREBASE_PROJECT_ID && firebase deploy --only firestore:rules`).
# The build does not read this; runtime uses VITE_FIREBASE_PROJECT_ID instead.
# Same value as VITE_FIREBASE_PROJECT_ID; duplicated so the deploy command works
# without sourcing `.env.local` carefully.
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
