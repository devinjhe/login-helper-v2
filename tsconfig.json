{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["chrome", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    ".wxt/wxt.d.ts",
    "src/**/*",
    "tests/**/*",
    "wxt.config.ts",
    "vitest.config.ts"
  ]
}
